APP_NAME=VibeMatching API
SERVICE_NAME=vibematching-backend
HEALTH_STATUS_OK=ok
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_PORT=8000

POSTGRES_USER=vibematching
POSTGRES_PASSWORD=vibematching
POSTGRES_DB=vibematching
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_CONTAINER_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_MANAGEMENT_PORT=15672

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=profile-photos
MINIO_SECURE=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
PHOTO_MAX_PER_PROFILE=5
PHOTO_MAX_FILE_SIZE_BYTES=5242880
PHOTO_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp
PHOTO_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.webp
FEED_BATCH_SIZE=20

POSTGRES_DOCKER_HOST=postgres
REDIS_DOCKER_HOST=redis
RABBITMQ_DOCKER_HOST=rabbitmq
MINIO_DOCKER_HOST=minio
